	quest.1C696378E17460EF.title: "中ぐり・The Cannon Drill"
	quest.1D01C3BE962CEFBB.title: "商いを交わす・What a Deal"
	quest.1D0CB6881B589C39.title: "笈・The Pilgrim's Pack"
	quest.1D489C9CFDD9C73A.title: "蕃茄・The Tomato Trellis"
	quest.1E73C1C3773B9EFF.title: "鞍を置く・Take to the Saddle"
	quest.205BA663E19548C9.title: "軸受・The Bearing"
	quest.20A82A3FBCFF9329.title: "薙刀・The Naginata"
	quest.20BE23EB72E1B753.title: "玉鋼の槍・The Tamahagane Yari"
	quest.229BEAF6B98B3606.title: "金棒・The Kanabō"
	quest.240CD9AECEE2AC65.title: "矢羽根・Fletching the Shaft"
	quest.278C4AF780BDC3CD.title: "石を割る・Break the Stone"
	quest.2863A45C9396D584.title: "蔵・A Place for Things"
	quest.28F21B6054511D63.title: "槍・The Ashigaru's Yari"
	quest.291C9BCFB855DCC2.title: "漬物・The Pickles"
	quest.2974D353AAC92E6D.title: "矢師の台・The Fletcher's Bench"
	quest.29EDC4F849FFC757.title: "大豆・Beans for Miso"
	quest.29F94703FCBD83D5.title: "的稽古・Target Practice"
	quest.2A600A89322A7B6F.title: "神火・The Spiritfire"
	quest.2AACB4605CB4EB43.title: "香・The Incense Offering"
	quest.2B3A218C4142DE0A.title: "膳を整える・A Warm Meal"
	quest.2BA19E928B00D575.title: "蒸気機関・The Steam Engine"
	quest.2C1CBF69C0156A37.title: "魂の提灯・The Soul Lantern"
	quest.2C8EACAE71FC1A02.title: "浪人・The Masterless"
	quest.2D0520FDEBCAB54C.title: "寿司・Sushi"
	quest.2DA8FF4557E10403.title: "黄泉比良坂・The Road to the Hells"
	quest.2E2B811814A8E7FF.title: "短刀・The Tantō"
	quest.2E35F79E7DB9BC08.title: "提灯・The Paper Lantern"
	quest.2EA67EF02761E5C5.title: "胴・The Dō"
	quest.2F654C03F7490860.title: "野伏の薙刀・The Nobushi's Naginata"
	quest.3155D36FFB0CE885.title: "提灯・The Paper Lantern"
	quest.319EF8A72650FB2A.title: "曼陀羅華・Demon's Dream"
	quest.3209E2F5918580B2.title: "占い・Divination"
	quest.324F8F95461CD654.title: "菅笠・The Farmer's Hat"
	quest.332F2EB4BE388BF6.title: "玉鋼の鎧・The Tamahagane Dō"
	quest.3380BB3BE3F6DD2E.title: "木刀・The Bokken"
	quest.343195BB775F1775.title: "速射砲・The Autocannon"
	quest.37BEED6D59538789.title: "濡女狩り・Hunting the Nure-onago"
	quest.38912F3C516DD314.title: "得物・A Warrior's First Blade"
	quest.39004B00A9D873F0.title: "鉄・First Iron"
	quest.3957AD92BF8A0A66.title: "野伏狩り・The Outlaw Ashigaru"
	quest.3A61F14D8B0AF22C.title: "帯と漏斗・Belt and Funnel"
	quest.3A80D6E0D9E6069F.title: "霊視の眼鏡・The Spirit-Sight Goggles"
	quest.3AB41662A8FE97A4.title: "写経・The Inscription Desk"
	quest.3CDBD022A559BE47.title: "木刀・The Practice Blade"
	quest.3D1AF6F2A709A2E4.title: "大根・The Daikon Bed"
	quest.3D9D9C516C37BA96.title: "散弾・Grapeshot"
	quest.3DB0527D3ACDA1DD.title: "玉鋼・Sand of the Gods"
	quest.3E28D9A7AD8DEED6.title: "兜・The Kabuto"
	quest.3ECCCECD32CF5242.title: "竈・The Hearth"
