	quest.16D45D5ED42F0A62.title: "野盗を討つ・Cut Down the Bandit"
	quest.18BE867921047AC5.title: "千両箱・The Thousand-Ryō Chest"
	quest.1A4BFF6DF127C5FF.title: "金貨・The Gold Koban"
	quest.1BABE988E1BC865B.title: "墨・Ink and Brush"
	quest.1C19A7D13FBAB074.title: "砂鉄・Satetsu"
